# ── Docker build context ignore ─────────────────────────

# Git
.git
.gitignore

# Node
frontend/node_modules
frontend/.nuxt
frontend/dist
frontend/.output

# PHP / Composer
api/vendor
api/node_modules

# Laravel generated
api/storage/logs/*
api/storage/framework/cache/*
api/storage/framework/sessions/*
api/storage/framework/views/*
api/bootstrap/cache/*
api/.env

# Docker compose (no es necesario en el contexto de build)
docker-compose*.yml

# Misc
*.md
.DS_Store
*.log
.env*
!.env.example
traefik/
memory/
